{
  "$schema": "xjson://schema/core/v1",
  "@id": "asx://schema/mx2lm.stream.v1",
  "@type": "schema",
  "@version": "1.0.0",
  "@status": "frozen",
  "@description": "MX2LM Model Streaming Endpoint Schema - Server-Sent Events interface",

  "definitions": {
    "StreamRequest": {
      "@id": "asx://schema/mx2lm.stream.request.v1",
      "@type": "object",
      "properties": {
        "message": {
          "@type": "string",
          "@required": true,
          "@description": "Input message to process"
        },
        "model_name": {
          "@type": "string",
          "@default": "mx2lm",
          "@description": "Target model identifier"
        }
      },
      "required": ["message"]
    },

    "SSEEvent": {
      "@id": "asx://schema/mx2lm.stream.sse.v1",
      "@type": "object",
      "properties": {
        "event": {
          "@type": "enum",
          "@values": ["connect", "message", "complete", "end"],
          "@default": "message"
        },
        "data": {
          "@type": "object",
          "@ref": "#/definitions/EventData"
        }
      }
    },

    "EventData": {
      "@id": "asx://schema/mx2lm.stream.data.v1",
      "@type": "union",
      "@variants": [
        { "@ref": "#/definitions/ConnectEvent" },
        { "@ref": "#/definitions/ThinkingEvent" },
        { "@ref": "#/definitions/ChunkEvent" },
        { "@ref": "#/definitions/CompleteEvent" }
      ]
    },

    "ConnectEvent": {
      "@id": "asx://schema/mx2lm.stream.connect.v1",
      "@type": "object",
      "properties": {
        "status": { "@type": "string", "@const": "connected" },
        "model": { "@type": "string" },
        "timestamp": { "@type": "integer", "@format": "unix_epoch" }
      }
    },

    "ThinkingEvent": {
      "@id": "asx://schema/mx2lm.stream.thinking.v1",
      "@type": "object",
      "properties": {
        "type": { "@type": "string", "@const": "thinking" },
        "content": { "@type": "string" },
        "progress": { "@type": "integer", "@min": 0, "@max": 100 }
      }
    },

    "ChunkEvent": {
      "@id": "asx://schema/mx2lm.stream.chunk.v1",
      "@type": "object",
      "properties": {
        "type": { "@type": "string", "@const": "chunk" },
        "content": { "@type": "string" },
        "chunk_index": { "@type": "integer", "@min": 0 },
        "total_chunks": { "@type": "integer", "@min": 1 },
        "progress": { "@type": "number", "@min": 0, "@max": 100 }
      }
    },

    "CompleteEvent": {
      "@id": "asx://schema/mx2lm.stream.complete.v1",
      "@type": "object",
      "properties": {
        "type": { "@type": "string", "@const": "complete" },
        "total_chunks": { "@type": "integer" },
        "tokens_estimated": { "@type": "integer" },
        "finish_reason": {
          "@type": "enum",
          "@values": ["stop", "length", "error"]
        },
        "model": { "@type": "string" },
        "processing_time": { "@type": "string" }
      }
    },

    "ModelResponse": {
      "@id": "asx://schema/mx2lm.stream.model_response.v1",
      "@type": "object",
      "properties": {
        "model_id": { "@type": "string" },
        "template": { "@type": "string" }
      }
    }
  },

  "@models": {
    "deepseek-r1": {
      "@id": "mx2lm://model/deepseek-r1",
      "@capabilities": ["reasoning", "quantum-enhanced", "multi-perspective"]
    },
    "deepseek-coder": {
      "@id": "mx2lm://model/deepseek-coder",
      "@capabilities": ["code-generation", "debugging", "optimization"]
    },
    "janus-pro": {
      "@id": "mx2lm://model/janus-pro",
      "@capabilities": ["quantum-lattice", "dual-perspective", "scxq2-compression"]
    },
    "janus-flow": {
      "@id": "mx2lm://model/janus-flow",
      "@capabilities": ["low-latency", "real-time", "efficient-tokens"]
    },
    "llama3": {
      "@id": "mx2lm://model/llama3",
      "@capabilities": ["general-purpose", "balanced"]
    },
    "mistral": {
      "@id": "mx2lm://model/mistral",
      "@capabilities": ["fast", "efficient", "scalable"]
    },
    "codellama": {
      "@id": "mx2lm://model/codellama",
      "@capabilities": ["code-generation", "multi-language"]
    },
    "qwen-coder": {
      "@id": "mx2lm://model/qwen-coder",
      "@capabilities": ["programming", "clean-code", "algorithms"]
    },
    "cline-agent": {
      "@id": "mx2lm://model/cline-agent",
      "@capabilities": ["task-execution", "tool-integration", "quantum-acceleration"]
    },
    "mx2-inference": {
      "@id": "mx2lm://model/mx2-inference",
      "@capabilities": ["batch-processing", "parallel", "scxq2-compression"]
    },
    "kuhul-quantum": {
      "@id": "mx2lm://model/kuhul-quantum",
      "@capabilities": ["quantum-superposition", "entanglement", "scxq2-compression"]
    }
  },

  "@pipeline": {
    "@stages": [
      {
        "@id": "validate",
        "@action": "validate_request",
        "@input": { "@ref": "#/definitions/StreamRequest" }
      },
      {
        "@id": "connect",
        "@action": "emit_sse",
        "@event": "connect",
        "@output": { "@ref": "#/definitions/ConnectEvent" }
      },
      {
        "@id": "thinking",
        "@action": "emit_thinking_steps",
        "@delay_ms": 200,
        "@steps": [
          { "content": "Processing your message...", "progress": 10 },
          { "content": "Analyzing with ${model_name}...", "progress": 30 },
          { "content": "Generating response...", "progress": 60 },
          { "content": "Finalizing output...", "progress": 90 }
        ]
      },
      {
        "@id": "stream_chunks",
        "@action": "stream_response",
        "@chunker": "sentence_split",
        "@delay_ms": { "@min": 100, "@max": 300 }
      },
      {
        "@id": "complete",
        "@action": "emit_sse",
        "@event": "complete",
        "@output": { "@ref": "#/definitions/CompleteEvent" }
      },
      {
        "@id": "end",
        "@action": "emit_sse",
        "@event": "end",
        "@output": { "status": "stream_complete" }
      }
    ]
  }
}
