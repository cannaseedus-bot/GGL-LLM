{
  "$schema": "ggl://schema/chat_template.compiled.v1",
  "@id": "kuhul://template/chat.compiled",
  "@version": "1.0.0",
  "@type": "compiled_template",
  "@source": "chat_template.ggl.svg",
  "@description": "Compiled chat template for MX2LM/Qwen inference - no SVG parsing required",

  "roles": {
    "system": {
      "id": 0,
      "prefix": "<|kuhul|>[Pop system]\n  [Wo content]→[Ch'en \"",
      "suffix": "\"]\n[Xul]\n"
    },
    "user": {
      "id": 1,
      "prefix": "<|kuhul|>[Pop user]\n  [Wo query]→[Ch'en \"",
      "suffix": "\"]\n[Xul]\n"
    },
    "assistant": {
      "id": 2,
      "prefix": "<|kuhul|>[Pop assistant]\n  [Wo response]→[Ch'en \"",
      "suffix": "\"]\n[Xul]\n"
    }
  },

  "phases": {
    "Pop": {
      "token_id": 300,
      "opens_scope": true,
      "description": "Entity existence"
    },
    "Wo": {
      "token_id": 301,
      "binds": "source",
      "description": "Source binding"
    },
    "Sek": {
      "token_id": 302,
      "executes": "transform",
      "description": "State transition"
    },
    "Ch'en": {
      "token_id": 303,
      "yields": "state",
      "description": "Crystallization"
    },
    "Yax": {
      "token_id": 304,
      "reads": "entity",
      "description": "Reference"
    },
    "Xul": {
      "token_id": 305,
      "closes_scope": true,
      "description": "Scope closure"
    }
  },

  "special_tokens": {
    "bos": "<|begin|>",
    "eos": "<|end|>",
    "pad": "<|pad|>",
    "kuhul_mode": "<|kuhul|>",
    "svg_mode": "<|svg|>",
    "ggl_mode": "<|ggl|>"
  },

  "stop_sequences": [
    "[Xul]",
    "<|end|>",
    "\n\n---\n"
  ],

  "generation_prompt": {
    "enabled": true,
    "template": "<|kuhul|>[Pop assistant]\n  [Wo response]→"
  },

  "render_slots": {
    "message_content": {
      "escape_quotes": true,
      "escape_newlines": false,
      "max_length": null
    }
  },

  "format_spec": {
    "newline": "\n",
    "indent": "  ",
    "phase_arrow": "→",
    "content_wrapper": "\""
  },

  "inference_config": {
    "add_bos": true,
    "add_eos_after_assistant": false,
    "strip_trailing_whitespace": true
  },

  "example": {
    "input": [
      {"role": "system", "content": "You are a K'UHUL assistant."},
      {"role": "user", "content": "Draw a circle."}
    ],
    "output": "<|kuhul|>[Pop system]\n  [Wo content]→[Ch'en \"You are a K'UHUL assistant.\"]\n[Xul]\n<|kuhul|>[Pop user]\n  [Wo query]→[Ch'en \"Draw a circle.\"]\n[Xul]\n<|kuhul|>[Pop assistant]\n  [Wo response]→"
  }
}
