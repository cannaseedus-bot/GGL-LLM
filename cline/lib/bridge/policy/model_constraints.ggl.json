{
  "$schema": "ggl://schema/constraints.v1",
  "@id": "kuhul://policy/constraints",
  "@version": "1.0.0",
  "safety": {
    "max_geometry_complexity": 10000,
    "max_boolean_depth": 5,
    "max_array_size": 1000,
    "timeout_ms": 30000
  },
  "memory": {
    "max_tensor_size_mb": 1024,
    "max_batch_size": 32,
    "cache_size_mb": 512
  },
  "execution": {
    "allow_eval": false,
    "deterministic": true,
    "reproducible_seed": true
  },
  "bridge": {
    "svg_output": true,
    "ggl_output": true,
    "threejs_output": true,
    "preserve_topology": true
  }
}