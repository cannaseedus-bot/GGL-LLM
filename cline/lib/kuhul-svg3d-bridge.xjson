{
  "$schema": "xjson://schema/core/v1",
  "@id": "asx://schema/kuhul.svg3d.bridge.v1",
  "@type": "schema",
  "@version": "1.0.0",
  "@status": "frozen",
  "@description": "K'UHUL SVG-3D ↔ GGL Bridge - Complete Bidirectional Interoperability",

  "@architecture": {
    "@principle": "Seamless interoperability between procedural (SVG-3D) and declarative (GGL) geometric languages",
    "@layers": {
      "translation": "SVG-3D Operators ↔ GGL Glyphs",
      "compilation": "GGL → Execution Plan",
      "execution": "Plan → Three.js Visualization",
      "visualization": "Runtime Visualization",
      "synchronization": "State Management"
    }
  },

  "@mappings": {
    "@svg3d_to_ggl": {
      "(⤍)": {
        "@ggl": "encrypt",
        "@params": ["vector", "path"],
        "@transform": "encrypt(${vector}, \"${path}\")",
        "@description": "ASC Cipher - encrypt vector along path"
      },
      "(⤎)": {
        "@ggl": "decrypt",
        "@params": ["encrypted", "path"],
        "@transform": "decrypt(${encrypted}, \"${path}\")",
        "@description": "ASC Cipher - decrypt along path"
      },
      "(↻)": {
        "@ggl": "rotate",
        "@params": ["geometry", "angle"],
        "@transform": "rotate(${geometry}, ${angle})",
        "@description": "SCX Compression - rotate geometry"
      },
      "(↔)": {
        "@ggl": "mirror",
        "@params": ["geometry", "axis"],
        "@transform": "mirror(${geometry}, \"${axis}\")",
        "@description": "SCX Compression - mirror geometry"
      },
      "(⟲)": {
        "@ggl": "spherical_grid",
        "@params": ["radius", "points"],
        "@transform": "spherical_grid(${radius}, ${points})",
        "@description": "3D Control - spherical point distribution"
      },
      "(⤦)": {
        "@ggl": "conditional",
        "@params": ["condition", "ifTrue", "ifFalse"],
        "@transform": "if ${condition} then ${ifTrue} else ${ifFalse}",
        "@description": "3D Control - conditional branching"
      },
      "(⟿)": {
        "@ggl": "generate_path",
        "@params": ["input", "seed"],
        "@transform": "generate_path(\"${input}\", ${seed})",
        "@description": "Neural Vector - AI path generation"
      },
      "(⤂)": {
        "@ggl": "apply_weights",
        "@params": ["geometry", "weights"],
        "@transform": "apply_weights(${geometry}, ${weights})",
        "@description": "Neural Vector - weight application"
      }
    },

    "@ggl_to_svg3d": {
      "◯": {
        "@svg3d": "create_sphere",
        "@params": ["radius"],
        "@description": "Circle/Sphere glyph"
      },
      "□": {
        "@svg3d": "create_cube",
        "@params": ["size"],
        "@description": "Square/Cube glyph"
      },
      "△": {
        "@svg3d": "create_tetrahedron",
        "@params": ["size"],
        "@description": "Triangle/Tetrahedron glyph"
      },
      "⍯": {
        "@svg3d": "boolean_union",
        "@params": ["objects"],
        "@description": "Boolean union operator"
      },
      "⍰": {
        "@svg3d": "boolean_difference",
        "@params": ["objects"],
        "@description": "Boolean difference operator"
      },
      "⍭": {
        "@svg3d": "boolean_intersection",
        "@params": ["objects"],
        "@description": "Boolean intersection operator"
      },
      "⍸": {
        "@svg3d": "radial_array",
        "@params": ["object", "count"],
        "@description": "Radial array operator"
      },
      "rotate": {
        "@svg3d": "(↻)",
        "@params": ["geometry", "angle"]
      },
      "mirror": {
        "@svg3d": "(↔)",
        "@params": ["geometry", "axis"]
      }
    }
  },

  "@pipeline": {
    "@translation": {
      "@stages": [
        { "@name": "tokenize", "@input": "source_code", "@output": "tokens" },
        { "@name": "parse", "@input": "tokens", "@output": "ast" },
        { "@name": "transform", "@input": "ast", "@output": "normalized_ast" },
        { "@name": "generate", "@input": "normalized_ast", "@output": "target_code" },
        { "@name": "optimize", "@input": "target_code", "@output": "optimized_code" }
      ]
    },

    "@compilation": {
      "@stages": [
        { "@name": "parse", "@input": "ggl_expression", "@output": "ggl_ast" },
        { "@name": "compile", "@input": "ggl_ast", "@output": "execution_plan" },
        { "@name": "optimize", "@input": "execution_plan", "@output": "optimized_plan" },
        { "@name": "execute", "@input": "optimized_plan", "@output": "three_js_scene" },
        { "@name": "render", "@input": "three_js_scene", "@output": "3d_visualization" }
      ]
    },

    "@visualization": {
      "@stages": [
        { "@name": "source_glyph", "@description": "Show source language representation" },
        { "@name": "bridge_animation", "@description": "Animate translation particles" },
        { "@name": "target_glyph", "@description": "Show target language representation" },
        { "@name": "execution_viz", "@description": "Visualize execution steps" },
        { "@name": "result_display", "@description": "Display final result" }
      ]
    }
  },

  "definitions": {
    "TranslationRecord": {
      "@id": "asx://schema/kuhul.bridge.translation.v1",
      "@type": "object",
      "properties": {
        "id": { "@type": "string", "@format": "uuid" },
        "timestamp": { "@type": "integer", "@format": "unix_epoch" },
        "source": {
          "@type": "object",
          "properties": {
            "language": { "@type": "enum", "@values": ["SVG-3D", "GGL"] },
            "code": { "@type": "string" },
            "ast": { "@ref": "#/definitions/AST" }
          }
        },
        "target": {
          "@type": "object",
          "properties": {
            "language": { "@type": "enum", "@values": ["SVG-3D", "GGL"] },
            "code": { "@type": "string" },
            "ast": { "@ref": "#/definitions/AST" }
          }
        },
        "mapping": { "@type": "string" },
        "performance": {
          "@type": "object",
          "properties": {
            "translationTime": { "@type": "number", "@unit": "ms" }
          }
        }
      }
    },

    "AST": {
      "@id": "asx://schema/kuhul.bridge.ast.v1",
      "@type": "object",
      "properties": {
        "type": { "@type": "string" },
        "operator": { "@type": "string" },
        "args": { "@type": "array" },
        "children": { "@type": "array", "@items": { "@ref": "#/definitions/AST" } },
        "timestamp": { "@type": "integer" },
        "size": { "@type": "integer" }
      }
    },

    "ExecutionPlan": {
      "@id": "asx://schema/kuhul.bridge.plan.v1",
      "@type": "object",
      "properties": {
        "id": { "@type": "string" },
        "ast": { "@ref": "#/definitions/AST" },
        "steps": {
          "@type": "array",
          "@items": { "@ref": "#/definitions/ExecutionStep" }
        },
        "optimizations": { "@type": "array", "@items": { "@type": "string" } },
        "compiledAt": { "@type": "integer" }
      }
    },

    "ExecutionStep": {
      "@id": "asx://schema/kuhul.bridge.step.v1",
      "@type": "object",
      "properties": {
        "type": { "@type": "enum", "@values": ["create", "transform", "combine"] },
        "operation": { "@type": "string" },
        "shape": { "@type": "string" },
        "params": { "@type": "object" }
      }
    },

    "BridgeState": {
      "@id": "asx://schema/kuhul.bridge.state.v1",
      "@type": "object",
      "properties": {
        "translations": { "@type": "array", "@items": { "@ref": "#/definitions/TranslationRecord" } },
        "compiledPrograms": { "@type": "object" },
        "activeMappings": { "@type": "object" },
        "performance": {
          "@type": "object",
          "properties": {
            "translationTime": { "@type": "number" },
            "compilationTime": { "@type": "number" },
            "executionTime": { "@type": "number" }
          }
        }
      }
    }
  },

  "@examples": {
    "svg3d_to_ggl": [
      {
        "@input": "(⟲) 1 360",
        "@output": "spherical_grid(1, 360)",
        "@description": "Spherical grid generation"
      },
      {
        "@input": "(⤍) vector path=\"M0,0 L10,10\"",
        "@output": "encrypt(vector, \"M0,0 L10,10\")",
        "@description": "Vector encryption along path"
      },
      {
        "@input": "(↻) geometry angle=45",
        "@output": "rotate(geometry, 45)",
        "@description": "Geometry rotation"
      }
    ],
    "ggl_to_svg3d": [
      {
        "@input": "◯ {r:5}",
        "@output": "create_sphere(5)",
        "@description": "Sphere creation"
      },
      {
        "@input": "◯ {r:5} ⍯ □ {s:10}",
        "@output": "boolean_union(create_sphere(5), create_cube(10))",
        "@description": "Boolean union of sphere and cube"
      },
      {
        "@input": "◯ ⍰ [ △ ⍸ 6 ]",
        "@output": "boolean_difference(create_sphere(1), radial_array(create_tetrahedron(1), 6))",
        "@description": "Complex boolean with radial array"
      }
    ],
    "ggl_patterns": {
      "gear": "◯ {r:10} ⍰ [ ◯ {r:8} ⍰ ( □ {s:2} ⍸ 20 ) ]",
      "web": "[ ◯ {r: r} | r in [1,2,3,4,5] ]",
      "lattice": "[ □ {s:1} at (x, y, z) | x in 0..2, y in 0..2, z in 0..2 ]"
    }
  },

  "@performance": {
    "translation": {
      "simple": { "@time": "<1ms" },
      "complex": { "@time": "5-10ms" },
      "large": { "@time": "50-100ms" }
    },
    "compilation": {
      "small": { "@time": "10-20ms" },
      "medium": { "@time": "50-100ms" },
      "large": { "@time": "200-500ms" }
    },
    "execution": {
      "simple": { "@time": "1-5ms" },
      "complex": { "@time": "10-50ms" },
      "visualization": { "@target": "60fps" }
    },
    "memory": {
      "ast_per_node": "~100 bytes",
      "context_per_step": "~1KB",
      "visualization": "10-100MB"
    }
  },

  "@three_js_integration": {
    "@shapes": {
      "sphere": "THREE.SphereGeometry(radius, 16, 16)",
      "cube": "THREE.BoxGeometry(size, size, size)",
      "tetrahedron": "THREE.TetrahedronGeometry(size)"
    },
    "@colors": {
      "sphere": "#16f2aa",
      "cube": "#9966ff",
      "tetrahedron": "#ff3366"
    },
    "@materials": {
      "@default": "THREE.MeshPhongMaterial({ transparent: true, opacity: 0.8 })"
    }
  }
}
