/* ========================================================
   K'UHUL SVG Emit Directives
   File: kuhul-emit.asx
   Java → SVG → K'UHUL execution bridge
   ======================================================== */

@module "kuhul.emit.v1"
@import "asx://schema/kuhul.svg.v1" as KuhulSchema
@import "asx://runtime/fs.v1" as FS
@import "asx://runtime/svg.v1" as SVG
@import "asx://runtime/log.v1" as Log

/* --------------------------------------------------------
   K'UHUL Phase Markers
   -------------------------------------------------------- */
@phase Pop   { @type "existence"   @creates "spatial_anchor" }
@phase Wo    { @type "source"      @binds "identity" }
@phase Sek   { @type "action"      @executes "transform" }
@phase Chen  { @type "completion"  @yields "state" }
@phase Yax   { @type "reference"   @reads "entity" }
@phase Xul   { @type "closure"     @closes "block" }

/* --------------------------------------------------------
   SVG as ABI - Core Emit Functions
   -------------------------------------------------------- */

/* Emit SVG state file (the canonical Java→K'UHUL bridge) */
@function @emit_svg(
    entity_id: String,
    geometry: Array,
    state: Object
) -> String {
    @let svg_content = SVG.create({
        @viewBox "0 0 1000 1000",
        @preserveAspectRatio "xMidYMid meet",
        @xmlns "http://www.w3.org/2000/svg",
        @xmlns:kuhul "kuhul://namespace/v1"
    })

    /* Embed K'UHUL phase metadata */
    @let metadata = SVG.element("metadata", {
        @children [
            SVG.element("kuhul:state", {
                @entity entity_id,
                @phase state.phase ?? "Chen",
                @timestamp @now(),
                @data @json(state)
            })
        ]
    })

    /* Add geometry as vector elements */
    @each geom in geometry {
        @let elem = @invoke @geometry_to_svg(geom)
        SVG.append(svg_content, elem)
    }

    SVG.prepend(svg_content, metadata)

    @let path = @resolve(__dirname, "../output/${entity_id}.svg")
    FS.write(path, SVG.serialize(svg_content))

    Log.info("Emitted: ${path}")
    @return path
}

/* Convert K'UHUL geometry to SVG elements */
@function @geometry_to_svg(geom: Object) -> SVGElement {
    @match geom.type {
        "path" => SVG.path({
            @d geom.d,
            @fill geom.fill ?? "none",
            @stroke geom.stroke ?? "#000",
            @stroke-width geom.strokeWidth ?? 1,
            @kuhul:id geom.id
        })

        "rect" => SVG.rect({
            @x geom.x,
            @y geom.y,
            @width geom.width,
            @height geom.height,
            @fill geom.fill ?? "none",
            @stroke geom.stroke ?? "#000",
            @kuhul:id geom.id
        })

        "circle" => SVG.circle({
            @cx geom.cx,
            @cy geom.cy,
            @r geom.r,
            @fill geom.fill ?? "none",
            @stroke geom.stroke ?? "#000",
            @kuhul:id geom.id
        })

        "group" => SVG.g({
            @transform geom.transform ?? "",
            @kuhul:id geom.id,
            @children @map(geom.children, c => @invoke @geometry_to_svg(c))
        })

        "coordinate_system" => @invoke @emit_coordinate_system(geom)

        @default => SVG.g({ @kuhul:unknown geom.type })
    }
}

/* --------------------------------------------------------
   Video Player Projection Shell
   -------------------------------------------------------- */

@function @emit_video_player(
    player_id: String,
    media_src: String = "",
    options: Object = {}
) -> String {
    /* [Pop kuhul_video_player] */
    @let player = {
        @id player_id,
        @type "video_player",
        @phase "Pop"
    }

    /* [Wo src "kuhul://video-player.svg"]→[Ch'en player] */
    @let shell_geometry = [
        {
            "type": "rect",
            "id": "player_frame",
            "x": 0, "y": 0,
            "width": 1000, "height": 562,
            "fill": "#000"
        },
        {
            "type": "group",
            "id": "controls",
            "transform": "translate(0, 520)",
            "children": [
                { "type": "rect", "id": "control_bar", "x": 0, "y": 0, "width": 1000, "height": 42, "fill": "#222" },
                { "type": "circle", "id": "play_btn", "cx": 500, "cy": 21, "r": 15, "fill": "#fff" }
            ]
        }
    ]

    /* [Yax player]→[Sek embed_media "..."] */
    @let state = {
        "phase": "Chen",
        "media": media_src,
        "controls": options.controls ?? true,
        "autoplay": options.autoplay ?? false,
        "state": media_src ? "loading" : "idle"
    }

    @return @invoke @emit_svg(player_id, shell_geometry, state)
}

/* --------------------------------------------------------
   Vector Green Screen Projection
   -------------------------------------------------------- */

@function @emit_green_screen(
    screen_id: String,
    grid_size: Integer = 100
) -> String {
    /* [Pop VectorGreenScreen] */
    @let screen = {
        @id screen_id,
        @type "vector_green_screen",
        @phase "Pop"
    }

    /* [Wo projection_surface]→[Ch'en svg_canvas] */
    /* [Pop use_as_coordinate_system] */
    @let coordinate_system = @invoke @create_spatial_grid(grid_size)

    @let geometry = [
        {
            "type": "rect",
            "id": "infinite_plane",
            "x": -50000, "y": -50000,
            "width": 100000, "height": 100000,
            "fill": "#00ff00"
        },
        coordinate_system
    ]

    @let state = {
        "phase": "Chen",
        "coordinate_system": {
            "origin": [0, 0],
            "basis_vectors": [[1, 0], [0, 1]],
            "scale": 1.0,
            "grid_size": grid_size
        },
        "ready_for_projection": true
    }

    @return @invoke @emit_svg(screen_id, geometry, state)
}

/* Create spatial grid as coordinate system */
@function @create_spatial_grid(size: Integer) -> Object {
    @let grid_lines = []

    /* Vertical lines */
    @for x from -5000 to 5000 step size {
        @push grid_lines, {
            "type": "path",
            "id": "grid_v_${x}",
            "d": "M ${x} -5000 L ${x} 5000",
            "stroke": "#00cc00",
            "strokeWidth": 0.5
        }
    }

    /* Horizontal lines */
    @for y from -5000 to 5000 step size {
        @push grid_lines, {
            "type": "path",
            "id": "grid_h_${y}",
            "d": "M -5000 ${y} L 5000 ${y}",
            "stroke": "#00cc00",
            "strokeWidth": 0.5
        }
    }

    /* Origin marker */
    @push grid_lines, {
        "type": "circle",
        "id": "origin",
        "cx": 0, "cy": 0, "r": 5,
        "fill": "#ff0000"
    }

    @return {
        "type": "group",
        "id": "coordinate_system",
        "children": grid_lines
    }
}

/* --------------------------------------------------------
   Emit Coordinate System
   -------------------------------------------------------- */
@function @emit_coordinate_system(geom: Object) -> SVGElement {
    @let group = SVG.g({
        @id geom.id ?? "coord_sys",
        @kuhul:type "coordinate_system",
        @kuhul:origin @json(geom.origin ?? [0, 0]),
        @kuhul:basis @json(geom.basis ?? [[1, 0], [0, 1]]),
        @kuhul:scale geom.scale ?? 1.0
    })

    /* Emit basis vectors as visual guides */
    @let x_axis = SVG.line({
        @x1 0, @y1 0, @x2 100, @y2 0,
        @stroke "#ff0000", @stroke-width 2,
        @marker-end "url(#arrow)"
    })

    @let y_axis = SVG.line({
        @x1 0, @y1 0, @x2 0, @y2 -100,
        @stroke "#00ff00", @stroke-width 2,
        @marker-end "url(#arrow)"
    })

    SVG.append(group, x_axis)
    SVG.append(group, y_axis)

    @return group
}

/* --------------------------------------------------------
   Raster to Vector Conversion (for green screen)
   -------------------------------------------------------- */
@function @raster_to_vector(
    video_frame: Bytes,
    options: Object = {}
) -> Object {
    /* [Yax video_source]→[Sek raster_to_vector]→[Ch'en vector_frames] */

    @let vector_frame = {
        "type": "group",
        "id": "vector_frame_${@now()}",
        "children": []
    }

    /* Extract motion fields, edges, contours */
    @let edges = @invoke @detect_edges(video_frame, options.threshold ?? 128)
    @let contours = @invoke @trace_contours(edges)

    @each contour in contours {
        @push vector_frame.children, {
            "type": "path",
            "id": "contour_${@index()}",
            "d": @invoke @contour_to_path(contour),
            "fill": "none",
            "stroke": "#000",
            "strokeWidth": 1
        }
    }

    @return vector_frame
}

/* Placeholder edge detection */
@function @detect_edges(frame: Bytes, threshold: Integer) -> Array {
    /* Actual implementation would use image processing */
    @return []
}

/* Placeholder contour tracing */
@function @trace_contours(edges: Array) -> Array {
    @return []
}

/* Convert contour points to SVG path */
@function @contour_to_path(contour: Array) -> String {
    @if @len(contour) < 2 {
        @return ""
    }

    @let d = "M ${contour[0].x} ${contour[0].y}"
    @for i from 1 to @len(contour) - 1 {
        d = "${d} L ${contour[i].x} ${contour[i].y}"
    }

    @return d
}

/* --------------------------------------------------------
   K'UHUL Block Builder
   -------------------------------------------------------- */

@function @kuhul_block(phase: String, target: String, binding: String = "") -> Object {
    @return {
        "phase": phase,
        "target": target,
        "binding": binding,
        "timestamp": @now(),
        "children": []
    }
}

@function @kuhul_chain(...blocks: Array) -> Object {
    @let root = blocks[0]
    @let current = root

    @for i from 1 to @len(blocks) - 1 {
        @push current.children, blocks[i]
        current = blocks[i]
    }

    @return root
}

/* --------------------------------------------------------
   Exports
   -------------------------------------------------------- */
@export {
    /* Core emit functions */
    @function @emit_svg,
    @function @emit_video_player,
    @function @emit_green_screen,
    @function @emit_coordinate_system,

    /* Geometry conversion */
    @function @geometry_to_svg,
    @function @create_spatial_grid,
    @function @raster_to_vector,

    /* K'UHUL block builders */
    @function @kuhul_block,
    @function @kuhul_chain,

    /* Phase markers */
    @phase Pop,
    @phase Wo,
    @phase Sek,
    @phase Chen,
    @phase Yax,
    @phase Xul
}

/* --------------------------------------------------------
   Module Load
   -------------------------------------------------------- */
@on_load {
    Log.debug("K'UHUL SVG emit module loaded")
    Log.debug("Phases: Pop → Wo → Sek → Ch'en → Yax → Xul")
    Log.debug("SVG is the ABI. Java speaks K'UHUL.")
}
