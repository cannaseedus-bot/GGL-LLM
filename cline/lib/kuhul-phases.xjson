{
  "$schema": "xjson://schema/core/v1",
  "@id": "asx://schema/kuhul.phases.v1",
  "@type": "schema",
  "@version": "1.0.0",
  "@status": "frozen",
  "@description": "K'UHUL Phase Execution Model - Formal semantics for spatial computing",

  "@law": {
    "@principle": "Existence precedes execution",
    "@corollary": "State is never evaluated, only projected"
  },

  "@phases": {
    "Pop": {
      "@id": "kuhul://phase/pop",
      "@glyph": "Pop",
      "@type": "existence",
      "@order": 1,
      "@semantics": {
        "@action": "Entity comes into existence",
        "@creates": "spatial_anchor",
        "@precondition": "none",
        "@postcondition": "entity.exists = true"
      },
      "@svg_mapping": {
        "@element": "g",
        "@attributes": { "kuhul:phase": "pop", "kuhul:entity": "${id}" }
      },
      "@example": "[Pop kuhul_video_player]"
    },

    "Wo": {
      "@id": "kuhul://phase/wo",
      "@glyph": "Wo",
      "@type": "source",
      "@order": 2,
      "@semantics": {
        "@action": "Origin binding / source declaration",
        "@binds": "identity",
        "@precondition": "entity.exists",
        "@postcondition": "entity.source = binding"
      },
      "@svg_mapping": {
        "@element": "use",
        "@attributes": { "href": "${src}", "kuhul:phase": "wo" }
      },
      "@example": "[Wo src \"kuhul://video-player.svg\"]"
    },

    "Sek": {
      "@id": "kuhul://phase/sek",
      "@glyph": "Sek",
      "@type": "action",
      "@order": 3,
      "@semantics": {
        "@action": "State transition / signal injection",
        "@executes": "transform",
        "@precondition": "entity.source != null",
        "@postcondition": "entity.state = transformed"
      },
      "@svg_mapping": {
        "@element": "animate",
        "@attributes": { "kuhul:phase": "sek", "kuhul:action": "${action}" }
      },
      "@example": "[Sek embed_media \"dQw4w9WgXcQ\"]"
    },

    "Chen": {
      "@id": "kuhul://phase/chen",
      "@glyph": "Ch'en",
      "@type": "completion",
      "@order": 4,
      "@semantics": {
        "@action": "State crystallization / result binding",
        "@yields": "state",
        "@precondition": "transform.complete",
        "@postcondition": "entity.state = crystallized"
      },
      "@svg_mapping": {
        "@element": "metadata",
        "@attributes": { "kuhul:phase": "chen", "kuhul:state": "${state}" }
      },
      "@example": "[Ch'en player]",
      "@notation": "→[Ch'en result] denotes transition to crystallized state"
    },

    "Yax": {
      "@id": "kuhul://phase/yax",
      "@glyph": "Yax",
      "@type": "reference",
      "@order": 5,
      "@semantics": {
        "@action": "Reference to existing entity",
        "@reads": "entity",
        "@precondition": "target.exists && target.state = crystallized",
        "@postcondition": "reference.valid = true"
      },
      "@svg_mapping": {
        "@element": "use",
        "@attributes": { "href": "#${ref}", "kuhul:phase": "yax" }
      },
      "@example": "[Yax player]→[Sek autoplay]"
    },

    "Xul": {
      "@id": "kuhul://phase/xul",
      "@glyph": "Xul",
      "@type": "closure",
      "@order": 6,
      "@semantics": {
        "@action": "Scope termination / phase boundary",
        "@closes": "block",
        "@precondition": "block.open",
        "@postcondition": "block.closed = true"
      },
      "@svg_mapping": {
        "@element": null,
        "@comment": "Xul closes the containing <g> element"
      },
      "@example": "[Xul]"
    }
  },

  "@transitions": {
    "@arrow": "→",
    "@description": "Phase transition operator",
    "@rules": [
      { "@from": "Pop", "@to": ["Wo", "Xul"], "@description": "Entity can bind source or close immediately" },
      { "@from": "Wo", "@to": ["Chen", "Sek"], "@description": "Source can crystallize or transform" },
      { "@from": "Sek", "@to": ["Chen", "Sek"], "@description": "Actions can chain or crystallize" },
      { "@from": "Chen", "@to": ["Yax", "Xul"], "@description": "State can be referenced or block closes" },
      { "@from": "Yax", "@to": ["Sek", "Xul"], "@description": "Reference can trigger action or close" },
      { "@from": "Xul", "@to": [], "@description": "Closure is terminal within block" }
    ]
  },

  "@block_structure": {
    "@description": "K'UHUL blocks are nested execution scopes",
    "@syntax": "[Pop entity] ... [Xul]",
    "@nesting": "Blocks can contain blocks",
    "@example": {
      "@kuhul": "[Pop VectorGreenScreen]\n  [Wo projection_surface]→[Ch'en svg_canvas]\n  [Pop use_as_coordinate_system]\n    [Yax green_screen_element]→[Sek create_spatial_grid]\n    [Yax grid]→[Ch'en coordinate_system]\n  [Xul]\n[Xul]",
      "@description": "Nested block creates coordinate system within green screen"
    }
  },

  "@examples": {
    "video_player": {
      "@description": "Complete video player instantiation",
      "@kuhul": "[Pop kuhul_video_player]\n  [Wo src \"kuhul://video-player.svg\"]→[Ch'en player]\n  [Yax player]→[Sek embed_media \"dQw4w9WgXcQ\"]\n  [Yax player]→[Sek set_controls true]\n  [Yax player]→[Sek autoplay]→[Ch'en playing]\n[Xul]",
      "@phases_used": ["Pop", "Wo", "Chen", "Yax", "Sek", "Xul"],
      "@svg_output": "video-player.svg with embedded state"
    },

    "vector_green_screen": {
      "@description": "Green screen as infinite coordinate plane",
      "@kuhul": "[Pop VectorGreenScreen]\n  [Wo projection_surface]→[Ch'en svg_canvas]\n  [Wo spatial_tracker]→[Ch'en vector_tracker]\n  [Pop use_as_coordinate_system]\n    [Yax green_screen_element]→[Sek create_spatial_grid]\n    [Yax grid]→[Ch'en coordinate_system]\n  [Xul]\n  [Pop project_as_vectors]\n    [Yax video_source]→[Sek raster_to_vector]→[Ch'en vector_frames]\n    [Yax vector_frames]→[Sek apply_spatial_transforms]\n    [Yax transformed]→[Sek render_to_svg]\n  [Xul]\n[Xul]",
      "@phases_used": ["Pop", "Wo", "Chen", "Yax", "Sek", "Xul"],
      "@svg_output": "Infinite coordinate plane with vector projections"
    }
  },

  "@invariants": [
    "Pop must precede any other phase for an entity",
    "Xul must close every Pop",
    "Chen yields immutable state",
    "Yax can only reference Chen'd entities",
    "Sek transforms but does not create",
    "No phase can eval external code"
  ],

  "@compression": {
    "@scxq2_compatible": true,
    "@description": "K'UHUL blocks compress well due to repetitive structure",
    "@dictionary_tokens": ["[Pop", "[Wo", "[Sek", "[Ch'en", "[Yax", "[Xul]", "→"]
  }
}
